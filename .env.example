# JobPulse Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# If keys are empty or set to 'mock', the application runs in a simulated mock mode.

# USAJobs API (Job Posting counts)
# Register at developer.usajobs.gov
USAJOBS_EMAIL=mock
USAJOBS_KEY=mock

# GNews API Configuration (Fetch hiring/layoff news)
# Obtain a key at gnews.io
GNEWS_API_KEY=mock

# Google Gemini API
# Obtain an API key at aistudio.google.com
GEMINI_API_KEY=mock
GEMINI_MODEL=gemini-2.5-flash

# Backend Configuration
PORT=8000
